<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dr. Ihab's Advanced Medical QBank</title>
    <!-- Tailwind CSS for Premium UI -->
    <script src="https://cdn.tailwindcss.com"></script>
    <!-- FontAwesome Icons -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Cairo:wght=300;400;600;700&display=swap" rel="stylesheet">
    
    <style>
        body {
            font-family: 'Cairo', sans-serif;
            background-color: #f8fafc;
        }
        ::-webkit-scrollbar {
            width: 6px;
        }
        ::-webkit-scrollbar-track {
            background: #f1f5f9;
        }
        ::-webkit-scrollbar-thumb {
            background: #cbd5e1;
            border-radius: 4px;
        }
        /* Strike-through styling */
        .struck-out {
            text-decoration: line-through;
            opacity: 0.4;
            pointer-events: none;
        }
        /* Key Info Highlight styling */
        .highlight-word {
            background-color: #fef08a;
            color: #1e293b;
            padding: 0 4px;
            border-radius: 4px;
            font-weight: bold;
        }
    </style>
</head>
<body class="min-h-screen flex flex-col">

    <!-- ================= AUTH SCREEN ================= -->
    <div id="auth-screen" class="flex-1 flex items-center justify-center p-4">
        <div class="bg-white p-8 rounded-2xl shadow-xl w-full max-w-lg border border-blue-100 transition-all">
            <div class="text-center mb-6">
                <div class="bg-gradient-to-tr from-blue-600 to-indigo-600 text-white w-16 h-16 rounded-2xl flex items-center justify-center mx-auto mb-4 text-2xl shadow-lg transform rotate-3">
                    <i class="fa-solid fa-user-md"></i>
                </div>
                <h1 class="text-2xl font-bold text-slate-800">Dr. Ihab's Advanced QBank</h1>
                <p class="text-slate-500 text-sm mt-1">بوابتك التفاعلية لاجتياز امتحانات البورد والـ USMLE بنجاح</p>
            </div>

            <!-- Login / Sign-up Form -->
            <form id="login-form" class="space-y-4">
                
                <!-- Fields shown only during Register Mode -->
                <div id="register-only-fields" class="hidden space-y-4 border-t border-slate-100 pt-4">
                    <div>
                        <label class="block text-sm font-semibold text-slate-700 mb-1">الاسم الكامل (ثنائي أو ثلاثي)</label>
                        <div class="relative">
                            <span class="absolute inset-y-0 right-0 flex items-center pr-3 text-slate-400">
                                <i class="fa-solid fa-id-card"></i>
                            </span>
                            <input type="text" id="auth-fullname" class="w-full pr-10 pl-4 py-2.5 bg-slate-50 border border-slate-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-blue-500 text-right" placeholder="د. أحمد محمد">
                        </div>
                    </div>

                    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                        <div>
                            <label class="block text-sm font-semibold text-slate-700 mb-1">المستوى الأكاديمي</label>
                            <select id="auth-level" class="w-full px-4 py-2.5 bg-slate-50 border border-slate-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-blue-500 text-right">
                                <option value="طالب طب">طالب طب (Medical Student)</option>
                                <option value="طبيب امتياز">طبيب امتياز (Intern)</option>
                                <option value="طبيب مقيم">طبيب مقيم (Resident)</option>
                                <option value="أخصائي">أخصائي (Specialist)</option>
                            </select>
                        </div>
                        <div>
                            <label class="block text-sm font-semibold text-slate-700 mb-1">الجامعة / المستشفى</label>
                            <input type="text" id="auth-institution" class="w-full px-4 py-2.5 bg-slate-50 border border-slate-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-blue-500 text-right" placeholder="مثال: جامعة الأهلي">
                        </div>
                    </div>
                </div>

                <!-- Basic Credentials (Always visible) -->
                <div>
                    <label class="block text-sm font-semibold text-slate-700 mb-1">البريد الإلكتروني</label>
                    <div class="relative">
                        <span class="absolute inset-y-0 right-0 flex items-center pr-3 text-slate-400">
                            <i class="fa-solid fa-envelope"></i>
                        </span>
                        <input type="email" id="auth-email" required class="w-full pr-10 pl-4 py-2.5 bg-slate-50 border border-slate-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-blue-500 text-right" placeholder="example@gmail.com">
                    </div>
                </div>

                <div>
                    <label class="block text-sm font-semibold text-slate-700 mb-1">كلمة المرور</label>
                    <div class="relative">
                        <span class="absolute inset-y-0 right-0 flex items-center pr-3 text-slate-400">
                            <i class="fa-solid fa-lock"></i>
                        </span>
                        <input type="password" id="auth-password" required class="w-full pr-10 pl-4 py-2.5 bg-slate-50 border border-slate-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-blue-500 text-right" placeholder="••••••••">
                    </div>
                </div>

                <button type="submit" id="auth-submit-btn" class="w-full bg-blue-600 hover:bg-blue-700 text-white font-semibold py-3 rounded-xl transition shadow-md shadow-blue-200 flex items-center justify-center gap-2">
                    <span>تسجيل الدخول</span>
                    <i class="fa-solid fa-arrow-left"></i>
                </button>
            </form>

            <div class="mt-6 text-center text-sm text-slate-500">
                <span id="auth-toggle-label">ليس لديك حساب؟</span> 
                <button id="toggle-auth-mode" class="text-blue-600 font-semibold hover:underline ml-1">إنشاء حساب جديد</button>
            </div>
        </div>
    </div>

    <!-- ================= MAIN APP SCREEN ================= -->
    <div id="app-screen" class="hidden flex-1 flex flex-col">
        <!-- Navigation Header -->
        <header class="bg-white border-b border-slate-100 shadow-sm sticky top-0 z-50">
            <div class="max-w-7xl mx-auto px-4 py-4 flex items-center justify-between">
                <div class="flex items-center gap-3">
                    <div class="bg-gradient-to-tr from-blue-600 to-indigo-600 text-white w-10 h-10 rounded-xl flex items-center justify-center shadow-md">
                        <i class="fa-solid fa-stethoscope text-lg"></i>
                    </div>
                    <div>
                        <h1 class="font-bold text-slate-800 leading-tight">Dr. Ihab's Advanced QBank</h1>
                        <span class="text-xs text-blue-600 font-semibold">بوابة التعليم الطبي القائم على الدليل</span>
                    </div>
                </div>
                <div class="flex items-center gap-4">
                    <span id="user-display-email" class="text-sm text-slate-600 hidden md:inline-block bg-slate-50 px-3 py-1.5 rounded-lg border border-slate-100"></span>
                    <button id="logout-btn" class="text-rose-600 hover:bg-rose-50 px-3 py-2 rounded-xl transition text-sm flex items-center gap-2 font-semibold">
                        <i class="fa-solid fa-sign-out-alt"></i>
                        <span>خروج</span>
                    </button>
                </div>
            </div>
        </header>

        <!-- Tabs Navigation -->
        <div class="bg-slate-50 border-b border-slate-100 py-3" id="navigation-tabs-bar">
            <div class="max-w-7xl mx-auto px-4 flex gap-2 overflow-x-auto">
                <button onclick="switchTab('add-questions-tab')" id="btn-add-questions-tab" class="tab-btn active px-5 py-2.5 rounded-xl font-semibold text-sm transition flex items-center gap-2 bg-blue-600 text-white shadow-sm shrink-0">
                    <i class="fa-solid fa-plus-circle"></i>
                    <span>إضافة وإدارة الأسئلة</span>
                </button>
                <button onclick="switchTab('exam-tab')" id="btn-exam-tab" class="tab-btn px-5 py-2.5 rounded-xl font-semibold text-sm text-slate-600 hover:bg-slate-200 transition flex items-center gap-2 shrink-0">
                    <i class="fa-solid fa-graduation-cap"></i>
                    <span>تقديم الامتحان المطور</span>
                </button>
                <button onclick="switchTab('profile-tab')" id="btn-profile-tab" class="tab-btn px-5 py-2.5 rounded-xl font-semibold text-sm text-slate-600 hover:bg-slate-200 transition flex items-center gap-2 shrink-0">
                    <i class="fa-solid fa-user-circle"></i>
                    <span>ملفي الطبي التفاعلي</span>
                </button>
            </div>
        </div>

        <!-- Main Content Area -->
        <main class="flex-1 max-w-7xl w-full mx-auto p-4 md:p-6">
            
            <!-- Tab 1: Add and Manage Questions (Only visible for Admin ihab) -->
            <section id="add-questions-tab" class="tab-content space-y-6">
                
                <!-- AI Smart Question Parser Assistant -->
                <div class="bg-gradient-to-r from-blue-900 to-indigo-950 text-white p-6 rounded-2xl shadow-xl border border-indigo-900">
                    <div class="flex items-start gap-4">
                        <div class="bg-white/10 text-cyan-300 p-3 rounded-xl text-xl">
                            <i class="fa-solid fa-wand-magic-sparkles"></i>
                        </div>
                        <div class="space-y-1 flex-1">
                            <h3 class="text-lg font-bold">مساعد التوليد التلقائي بالذكاء الاصطناعي (AI Auto-Fill)</h3>
                            <p class="text-sm text-slate-300">انسخ السؤال الطبي الذي قمت بتوليده بواسطة الذكاء الاصطناعي والصقه في الأسفل لكي يتم توزيعه وتعبئته داخل النموذج تلقائياً!</p>
                            
                            <div class="mt-4 space-y-3">
                                <textarea id="ai-raw-text" rows="3" class="w-full bg-black/20 border border-white/10 rounded-xl p-3 text-sm text-slate-100 focus:outline-none focus:ring-2 focus:ring-cyan-400 placeholder-slate-400 text-right" placeholder="لصق السؤال هنا (مثال: السؤال.. خيار أ.. خيار ب.. الإجابة الصحيحة.. التفسير الطبي..)"></textarea>
                                <button type="button" onclick="parseAIQuestion()" class="bg-cyan-500 hover:bg-cyan-600 text-slate-900 font-bold px-5 py-2.5 rounded-xl text-xs transition flex items-center gap-2">
                                    <i class="fa-solid fa-bolt"></i>
                                    <span>تحليل النص وملء النموذج بلمح البصر</span>
                                </button>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Manual Question Add Form -->
                <div class="bg-white p-6 rounded-2xl shadow-sm border border-slate-100">
                    <h3 class="text-lg font-bold text-slate-800 mb-6 flex items-center gap-2">
                        <i class="fa-solid fa-edit text-blue-600"></i>
                        <span>نموذج إضافة وحفظ سؤال جديد في السحابة</span>
                    </h3>

                    <form id="add-question-form" class="space-y-6">
                        <div>
                            <label class="block text-sm font-semibold text-slate-700 mb-1">نص السؤال الطبي (Clinical Scenario / Stem)</label>
                            <textarea id="q-stem" required rows="3" class="w-full px-4 py-2.5 bg-slate-50 border border-slate-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-blue-500 text-right" placeholder="اكتب سيناريو الحالة السريرية أو نص السؤال هنا..."></textarea>
                        </div>

                        <!-- Advanced Features Input -->
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                            <div>
                                <label class="block text-sm font-semibold text-slate-700 mb-1">الكلمات المفتاحية للتظليل تلقائياً (Key Info Highlight)</label>
                                <input type="text" id="q-key-highlight" class="w-full px-4 py-2.5 bg-slate-50 border border-slate-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-blue-500 text-right" placeholder="كلمة معينة بالسيناريو لتظهر مظللة بالأصفر">
                            </div>
                            <div>
                                <label class="block text-sm font-semibold text-slate-700 mb-1">نصيحة الطبيب المشرف (Attending Physician Tip)</label>
                                <input type="text" id="q-attending-tip" class="w-full px-4 py-2.5 bg-slate-50 border border-slate-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-blue-500 text-right" placeholder="تلميح ذكي لمساعدة الطالب دون إعطائه الجواب">
                            </div>
                        </div>

                        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                            <div>
                                <label class="block text-sm font-semibold text-slate-700 mb-1">الخيار (A)</label>
                                <input type="text" id="q-opt-a" required class="w-full px-4 py-2.5 bg-slate-50 border border-slate-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-blue-500 text-right" placeholder="أدخل الخيار الأول">
                            </div>
                            <div>
                                <label class="block text-sm font-semibold text-slate-700 mb-1">الخيار (B)</label>
                                <input type="text" id="q-opt-b" required class="w-full px-4 py-2.5 bg-slate-50 border border-slate-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-blue-500 text-right" placeholder="أدخل الخيار الثاني">
                            </div>
                            <div>
                                <label class="block text-sm font-semibold text-slate-700 mb-1">الخيار (C)</label>
                                <input type="text" id="q-opt-c" required class="w-full px-4 py-2.5 bg-slate-50 border border-slate-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-blue-500 text-right" placeholder="أدخل الخيار الثالث">
                            </div>
                            <div>
                                <label class="block text-sm font-semibold text-slate-700 mb-1">الخيار (D)</label>
                                <input type="text" id="q-opt-d" required class="w-full px-4 py-2.5 bg-slate-50 border border-slate-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-blue-500 text-right" placeholder="أدخل الخيار الرابع">
                            </div>
                        </div>

                        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                            <div>
                                <label class="block text-sm font-semibold text-slate-700 mb-1">الإجابة الصحيحة</label>
                                <select id="q-correct" required class="w-full px-4 py-2.5 bg-slate-50 border border-slate-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-blue-500 text-right">
                                    <option value="A">الخيار A</option>
                                    <option value="B">الخيار B</option>
                                    <option value="C">الخيار C</option>
                                    <option value="D">الخيار D</option>
                                </select>
                            </div>
                            <div>
                                <label class="block text-sm font-semibold text-slate-700 mb-1">تصنيف السؤال (طبي، أطفال، باطني..)</label>
                                <input type="text" id="q-category" class="w-full px-4 py-2.5 bg-slate-50 border border-slate-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-blue-500 text-right" placeholder="مثال: Cardiology">
                            </div>
                        </div>

                        <div>
                            <label class="block text-sm font-semibold text-slate-700 mb-1">الشرح الطبي التفصيلي والمبررات (Detailed Clinical Explanation)</label>
                            <textarea id="q-explanation" rows="4" class="w-full px-4 py-2.5 bg-slate-50 border border-slate-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-blue-500 text-right" placeholder="لماذا هذا الخيار صحيح؟ ولماذا الخيارات الأخرى خاطئة؟"></textarea>
                        </div>

                        <button type="submit" class="bg-blue-600 hover:bg-blue-700 text-white font-bold px-8 py-3 rounded-xl transition shadow-md shadow-blue-200 flex items-center gap-2">
                            <i class="fa-solid fa-save"></i>
                            <span>حفظ السؤال في قاعدة البيانات السحابية</span>
                        </button>
                    </form>
                </div>

                <!-- Database Live Questions Count & List -->
                <div class="bg-white p-6 rounded-2xl shadow-sm border border-slate-100">
                    <div class="flex items-center justify-between mb-6">
                        <h3 class="text-lg font-bold text-slate-800 flex items-center gap-2">
                            <i class="fa-solid fa-database text-blue-600"></i>
                            <span>بنك الأسئلة المضافة حالياً (<span id="total-questions-badge" class="text-blue-600">0</span>)</span>
                        </h3>
                    </div>
                    <div id="questions-list" class="space-y-4 max-h-[400px] overflow-y-auto pr-2">
                        <p class="text-slate-400 text-center py-4">جاري تحميل الأسئلة السحابية...</p>
                    </div>
                </div>

            </section>

            <!-- Tab 2: Take Exam (Student Practice Mode with AI) -->
            <section id="exam-tab" class="tab-content hidden space-y-6">
                <!-- AMBOSS & UWorld Mode Selector & Timer Header -->
                <div class="max-w-6xl mx-auto bg-white p-4 rounded-xl shadow-sm border border-slate-100 flex flex-wrap items-center justify-between gap-4">
                    <!-- Mode Switch -->
                    <div class="flex items-center gap-3">
                        <span class="text-sm font-bold text-slate-700">وضع الاختبار الحالي:</span>
                        <div class="flex bg-slate-100 p-1 rounded-lg">
                            <button id="mode-tutor-btn" onclick="toggleExamMode('tutor')" class="px-4 py-1.5 rounded-md text-xs font-bold bg-blue-600 text-white transition">Tutor (تدريب)</button>
                            <button id="mode-timed-btn" onclick="toggleExamMode('timed')" class="px-4 py-1.5 rounded-md text-xs font-bold text-slate-600 transition">Timed (امتحان)</button>
                        </div>
                    </div>
                    <!-- Real-Time Timer Display -->
                    <div id="exam-timer-container" class="hidden flex items-center gap-2 bg-rose-50 text-rose-700 px-4 py-2 rounded-xl border border-rose-100">
                        <i class="fa-solid fa-clock-rotate-left animate-spin-slow"></i>
                        <span class="text-sm font-bold">الوقت المتبقي للسؤال: <span id="exam-timer-count">90</span> ثانية</span>
                    </div>
                </div>

                <!-- Main Quiz Workspace & AI Assistant Grid -->
                <div class="grid grid-cols-1 lg:grid-cols-3 gap-6 max-w-6xl mx-auto items-start">
                    
                    <!-- Right: Exam Card (2 Columns wide) -->
                    <div class="lg:col-span-2 bg-white p-6 rounded-2xl shadow-sm border border-slate-100 space-y-6 animate-fade-in">
                        <div class="flex items-center justify-between border-b border-slate-100 pb-4">
                            <span class="text-xs bg-emerald-50 text-emerald-700 font-bold px-3 py-1.5 rounded-lg" id="student-exam-category">البورد الطبي والـ USMLE</span>
                            
                            <!-- Attending physician tip trigger -->
                            <button id="attending-tip-btn" onclick="revealAttendingTip()" class="text-amber-600 hover:bg-amber-50 border border-amber-100 px-3 py-1.5 rounded-xl transition text-xs font-semibold flex items-center gap-1.5">
                                <i class="fa-solid fa-lightbulb"></i>
                                <span>Attending physician's tip</span>
                            </button>

                            <div class="flex items-center gap-2 text-slate-600 font-semibold text-sm">
                                <span>السؤال</span>
                                <span id="current-question-index">1</span>
                                <span>من</span>
                                <span id="total-exam-questions">1</span>
                            </div>
                        </div>

                        <!-- Question Container -->
                        <div id="exam-card" class="space-y-6">
                            <h2 id="exam-q-stem" class="text-xl font-bold text-slate-800 leading-relaxed text-right"></h2>

                            <!-- Attending Tip Content Banner -->
                            <div id="attending-tip-banner" class="hidden bg-amber-50/70 border border-amber-200 p-4 rounded-xl text-xs text-amber-900 leading-relaxed">
                                <strong class="block mb-1 text-amber-800"><i class="fa-solid fa-user-doctor"></i> نصيحة الطبيب المشرف:</strong>
                                <span id="attending-tip-text"></span>
                            </div>

                            <!-- Options Choices Buttons -->
                            <div class="grid grid-cols-1 gap-3" id="exam-options-container">
                                <!-- Dynamically loaded options -->
                            </div>

                            <!-- TIMED MODE Submit Button (Initially hidden) -->
                            <div id="timed-submit-container" class="hidden text-center py-2">
                                <button onclick="submitTimedAnswer()" class="bg-indigo-600 hover:bg-indigo-700 text-white font-bold px-10 py-3 rounded-xl transition shadow-md">
                                    <i class="fa-solid fa-file-signature"></i>
                                    <span>إرسال الإجابة وتدقيقها</span>
                                </button>
                            </div>

                            <!-- Check Answer / Next Buttons -->
                            <div class="flex items-center justify-between pt-4 border-t border-slate-50">
                                <button id="prev-btn" onclick="prevQuestion()" class="bg-slate-100 hover:bg-slate-200 text-slate-700 font-bold px-6 py-3 rounded-xl transition flex items-center gap-2">
                                    <i class="fa-solid fa-arrow-right"></i>
                                    <span>السابق</span>
                                </button>
                                <button id="next-btn" onclick="nextQuestion()" class="bg-blue-600 hover:bg-blue-700 text-white font-bold px-6 py-3 rounded-xl transition flex items-center gap-2">
                                    <span>التالي</span>
                                    <i class="fa-solid fa-arrow-left"></i>
                                </button>
                            </div>

                            <!-- Explanation Area (Revealed on choice select) -->
                            <div id="explanation-box" class="hidden bg-blue-50 border-r-4 border-blue-500 p-5 rounded-xl space-y-2 transition-all">
                                <h4 class="font-bold text-blue-900 flex items-center gap-2">
                                    <i class="fa-solid fa-circle-info"></i>
                                    <span>التفسير والتحليل الطبي العلمي:</span>
                                </h4>
                                <p id="exam-q-explanation" class="text-slate-700 text-sm leading-relaxed text-right"></p>
                            </div>
                        </div>
                    </div>

                    <!-- Left: Integrated AI Assistant Panel -->
                    <div class="bg-slate-900 text-white rounded-2xl shadow-xl border border-slate-800 flex flex-col h-[580px]">
                        <!-- Assistant Header -->
                        <div class="p-4 bg-slate-950 rounded-t-2xl border-b border-slate-800 flex items-center gap-3">
                            <div class="bg-cyan-500 text-slate-950 w-8 h-8 rounded-lg flex items-center justify-center text-sm font-bold shadow-md animate-pulse">
                                <i class="fa-solid fa-robot"></i>
                            </div>
                            <div>
                                <h3 class="font-bold text-sm">مساعد الذكاء الاصطناعي الطبي</h3>
                                <span class="text-[10px] text-cyan-400">تواصل مباشر لشرح الحالات والفيزيولوجيا المرضية</span>
                            </div>
                        </div>

                        <!-- Chat Messages Container -->
                        <div id="ai-chat-messages" class="flex-1 p-4 overflow-y-auto space-y-3 text-xs flex flex-col">
                            <div class="bg-slate-800 text-slate-200 p-3 rounded-xl max-w-[85%] self-start leading-relaxed text-right">
