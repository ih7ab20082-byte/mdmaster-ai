    <!-- Firebase JS SDKs -->
    <script type="module">
        import { initializeApp } from "https://www.gstatic.com/firebasejs/10.8.0/firebase-app.js";
        import { getAuth, signInWithEmailAndPassword, createUserWithEmailAndPassword, signOut, onAuthStateChanged } from "https://www.gstatic.com/firebasejs/10.8.0/firebase-auth.js";
        import { getFirestore, collection, addDoc, getDocs, deleteDoc, doc, onSnapshot, setDoc, getDoc } from "https://www.gstatic.com/firebasejs/10.8.0/firebase-firestore.js";

        // ================= FIREBASE CONFIG =================
        const firebaseConfig = {
          apiKey: "AIzaSyDEB1mbvECCeghNAtmX7a0_kb5GE5Qfv9g",
          authDomain: "ihab-qbank.firebaseapp.com",
          projectId: "ihab-qbank",
          storageBucket: "ihab-qbank.firebasestorage.app",
          messagingSenderId: "77903804586",
          appId: "1:77903804586:web:ab6fdcf9b40e866ec4b8d3",
          measurementId: "G-64MCD2PKVN"
        };

        const app = initializeApp(firebaseConfig);
        const auth = getAuth(app);
        const db = getFirestore(app);

        // Memory variables
        let isSignUpMode = false;
        let allQuestions = [];
        let currentExamIndex = 0;
        let selectedOption = null;
        let currentUser = null;
        let currentUserProfile = null;
        let activeExamMode = 'tutor'; // 'tutor' or 'timed'
        let timerInterval = null;
        let secondsLeft = 90;

        const ADMIN_EMAIL = "ih7ab20082@gmail.com";

        // Dom Elements
        const authScreen = document.getElementById('auth-screen');
        const appScreen = document.getElementById('app-screen');
        const loginForm = document.getElementById('login-form');
        const authEmail = document.getElementById('auth-email');
        const authPassword = document.getElementById('auth-password');
        const authSubmitBtn = document.getElementById('auth-submit-btn');
        const toggleAuthMode = document.getElementById('toggle-auth-mode');
        const authToggleLabel = document.getElementById('auth-toggle-label');
        const registerOnlyFields = document.getElementById('register-only-fields');
        const logoutBtn = document.getElementById('logout-btn');
        const userDisplayEmail = document.getElementById('user-display-email');
        const addQuestionForm = document.getElementById('add-question-form');
        const questionsList = document.getElementById('questions-list');
        const totalQuestionsBadge = document.getElementById('total-questions-badge');
        const navigationTabsBar = document.getElementById('navigation-tabs-bar');

        // ================= AUTHENTICATION LOGIC =================
        onAuthStateChanged(auth, async (user) => {
            if (user) {
                currentUser = user;
                authScreen.classList.add('hidden');
                appScreen.classList.remove('hidden');
                userDisplayEmail.innerText = user.email;
                userDisplayEmail.classList.remove('hidden');
                
                await fetchAndRenderUserProfile();
                loadProgressionFromStorage();

                if (user.email.toLowerCase() === ADMIN_EMAIL.toLowerCase()) {
                    navigationTabsBar.classList.remove('hidden');
                    switchTab('add-questions-tab');
                } else {
                    navigationTabsBar.classList.add('hidden');
                    switchTab('exam-tab');
                }
                
                listenToQuestions();
            } else {
                currentUser = null;
                currentUserProfile = null;
                authScreen.classList.remove('hidden');
                appScreen.classList.add('hidden');
                userDisplayEmail.classList.add('hidden');
                clearInterval(timerInterval);
            }
        });

        toggleAuthMode.addEventListener('click', () => {
            isSignUpMode = !isSignUpMode;
            if (isSignUpMode) {
                authSubmitBtn.querySelector('span').innerText = "إنشاء الحساب وبدء التدريب";
                toggleAuthMode.innerText = "تسجيل الدخول بدلاً من ذلك";
                authToggleLabel.innerText = "بالفعل تملك حساباً؟";
                registerOnlyFields.classList.remove('hidden');
            } else {
                authSubmitBtn.querySelector('span').innerText = "تسجيل الدخول";
                toggleAuthMode.innerText = "إنشاء حساب جديد";
                authToggleLabel.innerText = "ليس لديك حساب؟";
                registerOnlyFields.classList.add('hidden');
            }
        });

        loginForm.addEventListener('submit', async (e) => {
            e.preventDefault();
            const email = authEmail.value;
            const password = authPassword.value;

            try {
                if (isSignUpMode) {
                    const fullName = document.getElementById('auth-fullname').value.trim();
                    const level = document.getElementById('auth-level').value;
                    const institution = document.getElementById('auth-institution').value.trim() || "غير محدد";

                    if (!fullName) {
                        alert("من فضلك أدخل الاسم الكامل لإتمام التسجيل.");
                        return;
                    }

                    const userCred = await createUserWithEmailAndPassword(auth, email, password);
                    const user = userCred.user;

                    await setDoc(doc(db, "users", user.uid), {
                        fullName: fullName,
                        level: level,
                        institution: institution,
                        email: email,
                        createdAt: new Date().toISOString()
                    });

                    alert("أهلاً بك يا دكتور! تم إنشاء ملفك الطبي التفاعلي بنجاح 🩺!");
                } else {
                    await signInWithEmailAndPassword(auth, email, password);
                }
            } catch (err) {
                alert("حدث خطأ أثناء المحاولة: " + err.message);
            }
        });

        logoutBtn.addEventListener('click', () => {
            signOut(auth).then(() => {
                alert("تم تسجيل الخروج بأمان. نراك قريباً!");
            });
        });

        // ================= USER ADVANCED PROFILE LOGIC =================
        async function fetchAndRenderUserProfile() {
            if (!currentUser) return;
            try {
                const userDoc = await getDoc(doc(db, "users", currentUser.uid));
                if (userDoc.exists()) {
                    currentUserProfile = userDoc.data();
                } else {
                    currentUserProfile = {
                        fullName: currentUser.email.toLowerCase() === ADMIN_EMAIL.toLowerCase() ? "أ.د. إيهاب أبو هليل" : "طبيب زائر",
                        level: currentUser.email.toLowerCase() === ADMIN_EMAIL.toLowerCase() ? "استشاري أول ومدير المنصة" : "غير محدد",
                        institution: currentUser.email.toLowerCase() === ADMIN_EMAIL.toLowerCase() ? "Al-Ahli Hospital" : "غير محدد",
                        email: currentUser.email
                    };
                }

                document.getElementById('profile-display-name').innerText = currentUserProfile.fullName;
                document.getElementById('profile-display-institution').innerText = currentUserProfile.institution;
                document.getElementById('profile-display-email').innerText = currentUserProfile.email;
                
                const roleBadge = document.getElementById('profile-badge-role');
                roleBadge.innerText = currentUserProfile.level;

                const avatar = document.getElementById('profile-avatar');
                const firstLetter = currentUserProfile.fullName ? currentUserProfile.fullName.trim().charAt(0) : "M";
                avatar.innerText = firstLetter;
            } catch (err) {
                console.error("Error fetching profile: ", err);
            }
        }

        window.triggerProfileEdit = async function() {
            if (!currentUserProfile) return;
            const newName = prompt("أدخل الاسم الجديد:", currentUserProfile.fullName);
            const newInst = prompt("أدخل اسم الجامعة / المستشفى الجديد:", currentUserProfile.institution);
            if (newName && newInst) {
                try {
                    await setDoc(doc(db, "users", currentUser.uid), {
                        ...currentUserProfile,
                        fullName: newName.trim(),
                        institution: newInst.trim()
                    }, { merge: true });
                    alert("تم تحديث بيانات ملفك الشخصي بنجاح 📋!");
                    await fetchAndRenderUserProfile();
                } catch (err) {
                    alert("تعذر تحديث البيانات: " + err.message);
                }
            }
        }

        // ================= EXAM MODES & TIMER LOGIC =================
        window.toggleExamMode = function(mode) {
            activeExamMode = mode;
            const tutorBtn = document.getElementById('mode-tutor-btn');
            const timedBtn = document.getElementById('mode-timed-btn');
            const timerContainer = document.getElementById('exam-timer-container');
            const timedSubmitBtn = document.getElementById('timed-submit-container');

            if (mode === 'tutor') {
                tutorBtn.className = "px-4 py-1.5 rounded-md text-xs font-bold bg-blue-600 text-white transition";
                timedBtn.className = "px-4 py-1.5 rounded-md text-xs font-bold text-slate-600 transition";
                timerContainer.classList.add('hidden');
                timedSubmitBtn.classList.add('hidden');
                clearInterval(timerInterval);
            } else {
                timedBtn.className = "px-4 py-1.5 rounded-md text-xs font-bold bg-blue-600 text-white transition";
                tutorBtn.className = "px-4 py-1.5 rounded-md text-xs font-bold text-slate-600 transition";
                timerContainer.classList.remove('hidden');
                startTimer();
            }
            loadExamQuestion();
        }

        function startTimer() {
            clearInterval(timerInterval);
            secondsLeft = 90;
            document.getElementById('exam-timer-count').innerText = secondsLeft;

            timerInterval = setInterval(() => {
                secondsLeft--;
                document.getElementById('exam-timer-count').innerText = secondsLeft;
                if (secondsLeft <= 0) {
                    clearInterval(timerInterval);
                    alert("انتهى وقت الإجابة المخصص لهذا السؤال ⏱️!");
                    submitTimedAnswer(true); // Auto submit blank/wrong
                }
            }, 1000);
        }

        // ================= ATTENDING PHYSICIAN TIP LOGIC =================
        window.revealAttendingTip = function() {
            const tipBanner = document.getElementById('attending-tip-banner');
            const tipText = document.getElementById('attending-tip-text');
            const currentQ = allQuestions[currentExamIndex];

            if (currentQ && currentQ.attendingTip) {
                tipText.innerText = currentQ.attendingTip;
                tipBanner.classList.toggle('hidden');
            } else {
                alert("لا توجد نصيحة مضافة للطبيب المشرف بخصوص هذا السؤال السريري.");
            }
        }

        // ================= QUESTION DATABASE LOGIC =================
        addQuestionForm.addEventListener('submit', async (e) => {
            e.preventDefault();
            const qData = {
                stem: document.getElementById('q-stem').value,
                keyHighlight: document.getElementById('q-key-highlight').value.trim() || "",
                attendingTip: document.getElementById('q-attending-tip').value.trim() || "",
                optA: document.getElementById('q-opt-a').value,
                optB: document.getElementById('q-opt-b').value,
                optC: document.getElementById('q-opt-c').value,
                optD: document.getElementById('q-opt-d').value,
                correct: document.getElementById('q-correct').value,
                category: document.getElementById('q-category').value.trim() || "General Medicine",
                explanation: document.getElementById('q-explanation').value || "No explanation provided.",
                createdAt: new Date().toISOString()
            };

            try {
                await addDoc(collection(db, "questions"), qData);
                alert("تم رفع السؤال السحابي وحفظه بنجاح 👍!");
                addQuestionForm.reset();
            } catch (err) {
                alert("خطأ أثناء حفظ السؤال: " + err.message);
            }
        });

        function listenToQuestions() {
            onSnapshot(collection(db, "questions"), (snapshot) => {
                allQuestions = [];
                questionsList.innerHTML = "";
                snapshot.forEach((doc) => {
                    allQuestions.push({ id: doc.id, ...doc.data() });
                });

                totalQuestionsBadge.innerText = allQuestions.length;
                document.getElementById('total-exam-questions').innerText = allQuestions.length || 1;

                if (allQuestions.length === 0) {
                    questionsList.innerHTML = `<p class="text-slate-400 text-center py-4">مخزن الأسئلة فارغ حالياً. أضف أسئلة للبدء!</p>`;
                    return;
                }

                allQuestions.forEach((q) => {
                    const qItem = document.createElement('div');
                    qItem.className = "p-4 bg-slate-50 border border-slate-100 rounded-xl flex items-start justify-between gap-4";
                    qItem.innerHTML = `
                        <div class="space-y-1 flex-1">
                            <span class="text-xs bg-blue-50 text-blue-600 font-bold px-2 py-1 rounded">${q.category}</span>
                            <p class="font-semibold text-slate-800 mt-2 text-right">${q.stem}</p>
                        </div>
                        <button onclick="deleteQuestion('${q.id}')" class="text-rose-500 hover:bg-rose-50 p-2 rounded-lg transition">
                            <i class="fa-solid fa-trash"></i>
                        </button>
                    `;
                    questionsList.appendChild(qItem);
                });

                loadExamQuestion();
            });
        }

        window.deleteQuestion = async function(id) {
            if (confirm("هل أنت متأكد من رغبتك في حذف هذا السؤال نهائياً من قاعدة البيانات السحابية؟")) {
                try {
                    await deleteDoc(doc(db, "questions", id));
                } catch (err) {
                    alert("خطأ في الحذف: " + err.message);
                }
            }
        }

        // ================= EXAM PROGRESSION & STATISTICS LOGIC =================
        let progression = {
            currentIndex: 0,
            answers: {}
        };

        function getStorageKey() {
            return `qbank_progression_${currentUser ? currentUser.uid : 'guest'}`;
        }

        function loadProgressionFromStorage() {
            const stored = localStorage.getItem(getStorageKey());
            if (stored) {
                progression = JSON.parse(stored);
                currentExamIndex = progression.currentIndex || 0;
            } else {
                progression = { currentIndex: 0, answers: {} };
                currentExamIndex = 0;
            }
            updateStatsUI();
        }

        function saveProgressionToStorage() {
            progression.currentIndex = currentExamIndex;
            localStorage.setItem(getStorageKey(), JSON.stringify(progression));
            updateStatsUI();
        }

        window.resetStudentProgress = function() {
            if (confirm("هل تريد بالتأكيد تصفير كافة إجاباتك السابقة والبدء مجدداً؟")) {
                progression = { currentIndex: 0, answers: {} };
                currentExamIndex = 0;
                localStorage.removeItem(getStorageKey());
                loadExamQuestion();
                updateStatsUI();
            }
        }

        function updateStatsUI() {
            const answeredIds = Object.keys(progression.answers);
            const totalResolved = answeredIds.length;
            let correctCount = 0;
            let incorrectCount = 0;

            answeredIds.forEach(id => {
                if (progression.answers[id].isCorrect) correctCount++;
                else incorrectCount++;
            });

            document.getElementById('profile-stats-resolved').innerText = totalResolved;
            document.getElementById('profile-stats-correct').innerText = correctCount;
            document.getElementById('profile-stats-incorrect').innerText = incorrectCount;

            const percentage = totalResolved > 0 ? Math.round((correctCount / totalResolved) * 100) : 0;
            document.getElementById('profile-stats-percentage').innerText = percentage + "%";

            const levelIndicator = document.getElementById('profile-level-indicator');
            if (totalResolved === 0) {
                levelIndicator.innerText = "بانتظار البدء 🏁";
                levelIndicator.className = "mt-3 text-xs bg-slate-100 text-slate-600 px-3 py-1 rounded-full font-bold";
            } else if (percentage >= 80) {
                levelIndicator.innerText = "جاهزية البورد ممتازة 🟢";
                levelIndicator.className = "mt-3 text-xs bg-emerald-100 text-emerald-800 px-3 py-1 rounded-full font-bold";
            } else if (percentage >= 60) {
                levelIndicator.innerText = "أداء معقول ومقبول 🟡";
                levelIndicator.className = "mt-3 text-xs bg-yellow-100 text-yellow-800 px-3 py-1 rounded-full font-bold";
            } else {
                levelIndicator.innerText = "يتطلب دراسة أعمق 🔴";
                levelIndicator.className = "mt-3 text-xs bg-rose-100 text-rose-800 px-3 py-1 rounded-full font-bold";
            }

            const circle = document.getElementById('profile-progress-ring');
            const radius = circle.r.baseVal.value;
            const circumference = radius * 2 * Math.PI;
            const offset = circumference - (percentage / 100) * circumference;
            circle.style.strokeDasharray = `${circumference} ${circumference}`;
            circle.style.strokeDashoffset = offset;

            renderSystemCompetencyBreakdown();
        }

        function renderSystemCompetencyBreakdown() {
            const container = document.getElementById('system-analytics-container');
            container.innerHTML = "";
            if (Object.keys(progression.answers).length === 0) {
                container.innerHTML = `<p class="text-slate-400 text-center text-xs py-4">ابدأ بحل الأسئلة لتظهر لك تحليلات كفاءتك الطبية هنا.</p>`;
                return;
            }

            const categoryStats = {};
            const questionMap = {};
            allQuestions.forEach(q => {
                questionMap[q.id] = q;
            });

            Object.keys(progression.answers).forEach(qId => {
                const answerInfo = progression.answers[qId];
                const qObj = questionMap[qId];
                if (qObj) {
                    const catName = qObj.category || "General Medicine";
                    if (!categoryStats[catName]) {
                        categoryStats[catName] = { total: 0, correct: 0 };
                    }
                    categoryStats[catName].total++;
                    if (answerInfo.isCorrect) {
                        categoryStats[catName].correct++;
                    }
                }
            });

            Object.keys(categoryStats).forEach(cat => {
                const stat = categoryStats[cat];
                const percentage = Math.round((stat.correct / stat.total) * 100);
                let barColor = "bg-rose-500";
                if (percentage >= 80) barColor = "bg-emerald-500";
                else if (percentage >= 65) barColor = "bg-blue-500";
                else if (percentage >= 50) barColor = "bg-yellow-500";

                const systemCard = document.createElement('div');
                systemCard.className = "space-y-1.5";
                systemCard.innerHTML = `
                    <div class="flex items-center justify-between text-xs">
                        <span class="font-bold text-slate-800">${cat}</span>
                        <span class="text-slate-500">تم حل ${stat.total} أسئلة • النسبة الصحيحة: <strong class="text-slate-900">${percentage}%</strong></span>
                    </div>
                    <div class="w-full bg-slate-100 rounded-full h-2">
                        <div class="${barColor} h-2 rounded-full transition-all duration-500" style="width: ${percentage}%"></div>
                    </div>
                `;
                container.appendChild(systemCard);
            });
        }

        // ================= EXAM / MCQ RENDER LOGIC =================
        function loadExamQuestion() {
            if (allQuestions.length === 0) {
                document.getElementById('exam-q-stem').innerText = "لا توجد أسئلة مضافة حتى الآن في الامتحان.";
                document.getElementById('exam-options-container').innerHTML = "";
                document.getElementById('explanation-box').classList.add('hidden');
                document.getElementById('attending-tip-banner').classList.add('hidden');
                return;
            }

            if (currentExamIndex >= allQuestions.length) currentExamIndex = allQuestions.length - 1;
            if (currentExamIndex < 0) currentExamIndex = 0;

            const currentQ = allQuestions[currentExamIndex];
            document.getElementById('current-question-index').innerText = currentExamIndex + 1;
            document.getElementById('student-exam-category').innerText = currentQ.category;
            document.getElementById('exam-q-explanation').innerText = currentQ.explanation;
            
            // Render Highlighting key terms if configured
            let stemText = currentQ.stem;
            if (currentQ.keyHighlight && stemText.includes(currentQ.keyHighlight)) {
                const regex = new RegExp(currentQ.keyHighlight, 'gi');
                stemText = stemText.replace(regex, `<span class="highlight-word">${currentQ.keyHighlight}</span>`);
            }
            document.getElementById('exam-q-stem').innerHTML = stemText;

            const explanationBox = document.getElementById('explanation-box');
            explanationBox.classList.add('hidden');
            document.getElementById('attending-tip-banner').classList.add('hidden');

            const optionsContainer = document.getElementById('exam-options-container');
            optionsContainer.innerHTML = "";
            selectedOption = null;

            const opts = [
                { key: 'A', value: currentQ.optA },
                { key: 'B', value: currentQ.optB },
                { key: 'C', value: currentQ.optC },
                { key: 'D', value: currentQ.optD }
            ];

            // Render option cards (Strikeout and Click selectors combined)
            opts.forEach(opt => {
                const div = document.createElement('div');
                div.className = "flex items-center gap-2 w-full";
                
                // Strikeout Button
                const strikeBtn = document.createElement('button');
                strikeBtn.type = "button";
                strikeBtn.className = "bg-slate-100 hover:bg-slate-200 text-slate-500 p-4 rounded-xl transition text-sm flex items-center justify-center shrink-0 w-12 h-[58px]";
                strikeBtn.innerHTML = `<i class="fa-solid fa-eye-slash"></i>`;
                strikeBtn.onclick = () => {
                    const textNode = div.querySelector('.option-text-holder');
                    textNode.classList.toggle('struck-out');
                };

                // Choice main select trigger
                const choiceBtn = document.createElement('button');
                choiceBtn.className = "option-text-holder flex-1 text-right p-4 bg-slate-50 hover:bg-slate-100 border border-slate-200 rounded-xl font-medium transition-all flex items-center justify-between";
                choiceBtn.innerHTML = `
                    <span>${opt.key}. ${opt.value}</span>
                    <i class="fa-regular fa-circle text-slate-300"></i>
                `;
                
                choiceBtn.onclick = () => {
                    if (activeExamMode === 'tutor') {
                        selectOption(choiceBtn, opt.key, currentQ.correct, currentQ.id);
                    } else {
                        // In Timed Mode: Just highlight selection visually first
                        highlightOnlyTemporary(choiceBtn, opt.key);
                    }
                };

                div.appendChild(choiceBtn);
                div.appendChild(strikeBtn);
                optionsContainer.appendChild(div);
            });

            // Adjust Timed Mode specific submit buttons
            if (activeExamMode === 'timed') {
                document.getElementById('timed-submit-container').classList.remove('hidden');
                startTimer();
            } else {
                document.getElementById('timed-submit-container').classList.add('hidden');
            }

            // Check if student already solved this question previously
            const savedAnswer = progression.answers[currentQ.id];
            if (savedAnswer) {
                explanationBox.classList.remove('hidden');
                selectedOption = savedAnswer.selectedOption;
                const divs = optionsContainer.children;
                Array.from(divs).forEach((div, idx) => {
                    const button = div.querySelector('.option-text-holder');
                    const optKey = ['A', 'B', 'C', 'D'][idx];
                    if (optKey === currentQ.correct) {
                        button.className = "option-text-holder flex-1 text-right p-4 bg-emerald-50 border border-emerald-500 text-emerald-800 font-semibold rounded-xl flex items-center justify-between";
                        button.querySelector('i').className = "fa-solid fa-circle-check text-emerald-500";
                    } else if (optKey === savedAnswer.selectedOption) {
                        button.className = "option-text-holder flex-1 text-right p-4 bg-rose-50 border border-rose-400 text-rose-800 rounded-xl flex items-center justify-between";
                        button.querySelector('i').className = "fa-solid fa-circle-xmark text-rose-500";
                    }
                });
                document.getElementById('timed-submit-container').classList.add('hidden');
                clearInterval(timerInterval);
            }
        }

        // Visual selection indicator for Timed Mode (Before hitting submit)
        function highlightOnlyTemporary(selectedBtn, key) {
            selectedOption = key;
            const optionsContainer = document.getElementById('exam-options-container');
            const divs = optionsContainer.children;
            Array.from(divs).forEach(div => {
                const btn = div.querySelector('.option-text-holder');
                btn.className = "option-text-holder flex-1 text-right p-4 bg-slate-50 hover:bg-slate-100 border border-slate-200 rounded-xl font-medium transition-all flex items-center justify-between";
                btn.querySelector('i').className = "fa-regular fa-circle text-slate-300";
            });

            selectedBtn.className = "option-text-holder flex-1 text-right p-4 bg-blue-50 border border-blue-400 text-blue-900 font-bold rounded-xl flex items-center justify-between";
            selectedBtn.querySelector('i').className = "fa-solid fa-circle text-blue-500";
        }

        // TIMED MODE Verification Trigger
        window.submitTimedAnswer = function(autoTimeout = false) {
            const currentQ = allQuestions[currentExamIndex];
            if (!currentQ) return;

            clearInterval(timerInterval);

            if (!selectedOption && !autoTimeout) {
                alert("يرجى اختيار خيار أولاً قبل الإرسال!");
                return;
            }

            const finalSelected = selectedOption || "WRONG_TIMEOUT";
            const isCorrect = (finalSelected === currentQ.correct);

            progression.answers[currentQ.id] = {
                selectedOption: finalSelected,
                isCorrect: isCorrect
            };
            saveProgressionToStorage();

            document.getElementById('timed-submit-container').classList.add('hidden');
            loadExamQuestion(); // Reload question cards to present color feedback + detailed rationales
        }

        // TUTOR MODE Immediate Selection Verification
        function selectOption(btn, key, correctKey, questionId) {
            if (selectedOption !== null || progression.answers[questionId]) return;

            selectedOption = key;
            const isCorrect = (key === correctKey);
            
            progression.answers[questionId] = {
                selectedOption: key,
                isCorrect: isCorrect
            };
            saveProgressionToStorage();

            const explanationBox = document.getElementById('explanation-box');
            explanationBox.classList.remove('hidden');

            const optionsContainer = document.getElementById('exam-options-container');
            const divs = optionsContainer.children;

            Array.from(divs).forEach((div, idx) => {
                const button = div.querySelector('.option-text-holder');
                const optKey = ['A', 'B', 'C', 'D'][idx];
                if (optKey === correctKey) {
                    button.className = "option-text-holder flex-1 text-right p-4 bg-emerald-50 border border-emerald-500 text-emerald-800 font-semibold rounded-xl flex items-center justify-between";
                    button.querySelector('i').className = "fa-solid fa-circle-check text-emerald-500";
                } else if (optKey === key) {
                    button.className = "option-text-holder flex-1 text-right p-4 bg-rose-50 border border-rose-400 text-rose-800 rounded-xl flex items-center justify-between";
                    button.querySelector('i').className = "fa-solid fa-circle-xmark text-rose-500";
                }
            });
        }

        window.nextQuestion = function() {
            if (currentExamIndex < allQuestions.length - 1) {
                currentExamIndex++;
                saveProgressionToStorage();
                loadExamQuestion();
            } else {
                alert("لقد وصلت إلى نهاية الأسئلة المتاحة حالياً 🎉!");
            }
        }

        window.prevQuestion = function() {
            if (currentExamIndex > 0) {
                currentExamIndex--;
                saveProgressionToStorage();
                loadExamQuestion();
            }
        }

        // ================= INTEGRATED AI ASSISTANT CLINICAL SYSTEM =================
        window.sendQuickQuery = function(suggestion) {
            document.getElementById('ai-chat-input').value = suggestion;
            sendAIChatMessage();
        }

        window.sendAIChatMessage = function() {
            const input = document.getElementById('ai-chat-input');
            const text = input.value.trim();
            if (!text) return;

            const container = document.getElementById('ai-chat-messages');
            const userMsg = document.createElement('div');
            userMsg.className = "bg-cyan-950 text-cyan-200 p-3 rounded-xl max-w-[85%] self-end leading-relaxed text-right";
            userMsg.innerText = text;
            container.appendChild(userMsg);
            input.value = "";
            container.scrollTop = container.scrollHeight;

            setTimeout(() => {
                const aiMsg = document.createElement('div');
                aiMsg.className = "bg-slate-800 text-slate-200 p-3 rounded-xl max-w-[85%] self-start leading-relaxed space-y-2";
                const currentQ = allQuestions[currentExamIndex];
                let responseHTML = "";

                if (text.includes("شرح تفصيلي للسؤال") && currentQ) {
                    responseHTML = `
                        <p class="font-bold text-cyan-400">تحليل الحالة السريرية الحالية (Clinical Scenario):</p>
                        <p class="text-slate-300">${currentQ.stem}</p>
                        <hr class="border-slate-700 my-2">
                        <p class="font-bold text-emerald-400">آلية التفسير الطبي المعتمد:</p>
                        <p>${currentQ.explanation}</p>
                        <hr class="border-slate-700 my-2">
                        <p class="font-bold text-yellow-400">جدول مقارنة التشخيصات المرافقة للفيزيولوجيا:</p>
                        <div class="overflow-x-auto my-2 rounded-lg border border-slate-700">
                            <table class="w-full text-right text-[10px]">
                                <thead class="bg-slate-900 text-slate-300">
                                    <tr>
                                        <th class="p-1.5 border border-slate-700">الحالة الطبية</th>
                                        <th class="p-1.5 border border-slate-700">الآلية الممرضة</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <tr class="bg-slate-850">
                                        <td class="p-1.5 border border-slate-700 font-bold">${currentQ.category}</td>
                                        <td class="p-1.5 border border-slate-700">اضطراب حيوي / التهابي حاد</td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>
                    `;
                } else if (text.includes("التشخيص التفريقي") && currentQ) {
                    responseHTML = `
                        <p class="font-bold text-cyan-400">التشخيص التفريقي (Differential Diagnosis - DDx):</p>
                        <p class="text-slate-300">بناءً على معطيات الفئة <span class="text-emerald-400 font-bold">${currentQ.category}</span>، إليك جدول التفريق السريري السريع:</p>
                        <div class="overflow-x-auto my-2 rounded-lg border border-slate-700">
                            <table class="w-full text-right text-[10px]">
                                <thead class="bg-slate-900 text-slate-300">
                                    <tr>
                                        <th class="p-1.5 border border-slate-700">المتلازمة</th>
                                        <th class="p-1.5 border border-slate-700">الأعراض السريرية الفاصلة</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <tr>
                                        <td class="p-1.5 border border-slate-700 font-bold">الحالة الأساسية</td>
                                        <td class="p-1.5 border border-slate-700">علامات إيجابية حادة، تبدلات مخبرية نوعية</td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>
                    `;
                } else {
                    responseHTML = `
                        <p class="font-bold text-cyan-400">إجابة المساعد الطبي الذكي:</p>
                        <p>بخصوص استفسارك عن: "${text}".</p>
                        <p class="text-slate-300 leading-relaxed">بناءً على الطب القائم على الدليل (EBP)، نوصي بربط القصة المرضية المفصلة للمريض بالفحوصات السريرية لتجنب أي تداخل في القرار الطبي.</p>
                    `;
                }

                aiMsg.innerHTML = responseHTML;
                container.appendChild(aiMsg);
                container.scrollTop = container.scrollHeight;
            }, 1000);
        }

        // ================= TAB MANAGEMENT =================
        window.switchTab = function(tabId) {
            document.querySelectorAll('.tab-content').forEach(content => {
                content.classList.add('hidden');
            });
            document.getElementById(tabId).classList.remove('hidden');

            document.querySelectorAll('.tab-btn').forEach(btn => {
                btn.className = "tab-btn px-5 py-2.5 rounded-xl font-semibold text-sm text-slate-600 hover:bg-slate-200 transition flex items-center gap-2";
            });

            const activeBtn = document.getElementById('btn-' + tabId);
            if (activeBtn) {
                activeBtn.className = "tab-btn active px-5 py-2.5 rounded-xl font-semibold text-sm transition flex items-center gap-2 bg-blue-600 text-white shadow-sm";
            }
        }

        // ================= AI PARSING ALGORITHM =================
        window.parseAIQuestion = function() {
            const rawText = document.getElementById('ai-raw-text').value;
            if (!rawText.trim()) {
                alert("من فضلك الصق نص السؤال الطبي هنا لكي أقوم بتحليله!");
                return;
            }

            try {
                const stemMatch = rawText.match(/السؤال[\s\S]*?\n([\s\S]*?)(?=أ\)|A\)|1\))/i) || rawText.match(/^([\s\S]*?)(?=A\)|A\.|أ\.)/);
                const optAMatch = rawText.match(/(?:A\)|A\.|أ\))\s*([^\n]+)/i);
                const optBMatch = rawText.match(/(?:B\)|B\.|ب\))\s*([^\n]+)/i);
                const optCMatch = rawText.match(/(?:C\)|C\.|ج\))\s*([^\n]+)/i);
                const optDMatch = rawText.match(/(?:D\)|D\.|د\))\s*([^\n]+)/i);
                const correctMatch = rawText.match(/(?:الإجابة الصحيحة|الجواب|Correct Answer|Correct|الإجابة)\s*[:\-]?\s*([A-Dأ-د])/i);
                const explanationMatch = rawText.match(/(?:التفسير|الشرح|Explanation|Rationale)\s*[:\-]?\s*([\s\S]*)$/i);

                if (stemMatch) document.getElementById('q-stem').value = stemMatch[1].trim();
                if (optAMatch) document.getElementById('q-opt-a').value = optAMatch[1].trim();
                if (optBMatch) document.getElementById('q-opt-b').value = optBMatch[1].trim();
                if (optCMatch) document.getElementById('q-opt-c').value = optCMatch[1].trim();
                if (optDMatch) document.getElementById('q-opt-d').value = optDMatch[1].trim();
                
                if (correctMatch) {
                    let ans = correctMatch[1].trim().toUpperCase();
                    if (ans === 'أ') ans = 'A';
                    if (ans === 'ب') ans = 'B';
                    if (ans === 'ج') ans = 'C';
                    if (ans === 'د') ans = 'D';
                    document.getElementById('q-correct').value = ans;
                }
                if (explanationMatch) document.getElementById('q-explanation').value = explanationMatch[1].trim();

                alert("تم تحليل سؤال الذكاء الاصطناعي بنجاح وتعبئة الحقول! يرجى مراجعتها ثم الضغط على زر الحفظ السحابي.");
            } catch (err) {
                alert("لم أتمكن من تفكيك النص بشكل تلقائي، يرجى ملء الحقول يدوياً أو تعديل صيغة النص قليلاً.");
            }
        }
    </script>
